clean-stale-branches() {
  DRY_RUN=false bash ~/Developer/git/shell-functions/bin/clean-stale-branches.sh
  playsound-4
}

clean-stale-branches-dr() {
  DRY_RUN=true bash ~/Developer/git/shell-functions/bin/clean-stale-branches.sh
  playsound-7
}

update-local-branches() {
  bash ~/Developer/git/shell-functions/bin/update-local-branches.sh "$@"
  playsound-5
}

checkout-my-branches() {
  bash ~/Developer/git/shell-functions/bin/checkout-my-branches.sh "$@"
